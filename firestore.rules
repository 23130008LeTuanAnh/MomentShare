rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.role == "ADMIN"
        && currentUserDoc().data.status == "active";
    }

    function isActiveUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.status == "active";
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // USERS
    match /users/{userId} {
      // Cho phép đọc users để kiểm tra username/email lúc đăng ký và tìm bạn.
      allow get, list: if true;

      allow create: if isSelf(userId);

      allow update: if isAdmin()
        || isSelf(userId);

      allow delete: if isAdmin();
    }

    // FRIEND REQUESTS
    match /friend_requests/{requestId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId;

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.receiverId ||
          isAdmin()
        );
    }

    // FRIENDS
    match /friends/{friendId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && (
          request.auth.uid == request.resource.data.userId ||
          request.auth.uid == request.resource.data.friendUserId
        );

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.friendUserId ||
          isAdmin()
        );
    }

    // MOMENTS
    match /moments/{momentId} {
      allow read: if signedIn();

      // Code hiện tại lưu người gửi bằng senderId.
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.imageUrl is string
        && request.resource.data.status == "active";

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.senderId ||
          isAdmin()
        );
    }

    // MOMENT RECEIVERS
    match /moment_receivers/{receiverDocId} {
      allow read: if signedIn();

      // MomentRepository đã bổ sung senderId vào moment_receivers để kiểm tra người gửi.
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.receiverId is string
        && request.resource.data.momentId is string;

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.receiverId ||
          request.auth.uid == resource.data.senderId ||
          isAdmin()
        );
    }

    // REACTIONS
    match /reactions/{reactionId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId;

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.userId ||
          isAdmin()
        );
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if signedIn()
        && (
          request.auth.uid == resource.data.userId ||
          isAdmin()
        );

      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.message is string;

      allow update, delete: if signedIn()
        && (
          request.auth.uid == resource.data.userId ||
          isAdmin()
        );
    }

    // REPORTS
    match /reports/{reportId} {
      allow create: if signedIn();

      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.reporterId == request.auth.uid
        );

      allow update, delete: if isAdmin();
    }

    // Dự phòng cho các collection khác trong lúc test/demo.
    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
