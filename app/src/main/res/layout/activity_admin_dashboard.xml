<?xml version="1.0" encoding="utf-8"?>

<!--
    Người 5 thêm: layout Admin Dashboard.
    Màn hình dùng để xem thống kê nhanh và mở các chức năng quản trị cơ bản.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtAdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Admin Dashboard"
            android:textColor="#111827"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Theo dõi nhanh dữ liệu hệ thống và xử lý các phần quản trị cơ bản."
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tổng người dùng"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTotalUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tổng khoảnh khắc"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTotalMoments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tổng báo cáo"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTotalReports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Báo cáo đang chờ"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtPendingReports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#DC2626"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tài khoản bị khóa"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLockedUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnManageUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="50dp"
            android:text="Quản lý người dùng"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnManageReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="50dp"
            android:text="Quản lý báo cáo"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="50dp"
            android:text="Xem thống kê chi tiết"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSeedDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="50dp"
            android:text="Tạo dữ liệu demo"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnBackProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="50dp"
            android:text="Quay lại hồ sơ"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
