<?xml version="1.0" encoding="utf-8"?>

<!--
    Layout màn hình đăng nhập của ứng dụng MomentShare.

    File này thuộc phần Người 1 - Tài khoản, hồ sơ cá nhân.

    Chức năng:
    - Nhập email hoặc username.
    - Nhập mật khẩu.
    - Bấm nút đăng nhập.
    - Chuyển sang màn hình đăng ký nếu chưa có tài khoản.
    - Hiển thị ProgressBar khi đang xử lý đăng nhập Firebase.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnBackLogin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Quay lại" />

        <!-- Tiêu đề màn hình đăng nhập -->
        <TextView
            android:id="@+id/txtLoginTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:gravity="center"
            android:text="Đăng nhập"
            android:textColor="#222222"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Mô tả ngắn -->
        <TextView
            android:id="@+id/txtLoginSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Chào mừng bạn quay lại MomentShare"
            android:textColor="#777777"
            android:textSize="14sp" />

        <!-- Ô nhập email hoặc username -->
        <EditText
            android:id="@+id/edtAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@android:drawable/edit_text"
            android:hint="Email hoặc username"
            android:inputType="textEmailAddress"
            android:minHeight="48dp"
            android:padding="12dp"
            android:textColor="#222222"
            android:textColorHint="#999999" />

        <!-- Ô nhập mật khẩu -->
        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@android:drawable/edit_text"
            android:hint="Mật khẩu"
            android:inputType="textPassword"
            android:minHeight="48dp"
            android:padding="12dp"
            android:textColor="#222222"
            android:textColorHint="#999999" />

        <!-- ProgressBar hiển thị khi đang đăng nhập Firebase -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

        <!-- Nút đăng nhập -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="50dp"
            android:text="Đăng nhập"
            android:textAllCaps="false" />

        <!-- Text chuyển sang màn hình đăng ký -->
        <TextView
            android:id="@+id/txtGoToRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Chưa có tài khoản? Đăng ký"
            android:textColor="#1976D2"
            android:textSize="15sp" />

    </LinearLayout>

</ScrollView>
