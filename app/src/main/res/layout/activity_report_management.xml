<?xml version="1.0" encoding="utf-8"?>

<!--
    Report Management redesigned.
    Giữ nguyên id: progressBar, txtEmptyReports, listReports.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_admin_screen"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="26dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_admin_hero"
        android:elevation="5dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý báo cáo"
            android:textColor="#171717"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Xem ảnh bị báo cáo và chọn ẩn khoảnh khắc hoặc bỏ qua báo cáo."
            android:textColor="#5F5F5F"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_admin_chip_warn"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Ưu tiên xử lý report pending"
            android:textColor="#7A3415"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtEmptyReports"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_admin_empty_card"
        android:gravity="center"
        android:minHeight="86dp"
        android:padding="16dp"
        android:text="Chưa có báo cáo"
        android:textColor="#6B6B6B"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_admin_list_card"
        android:orientation="vertical"
        android:padding="8dp">

        <ListView
            android:id="@+id/listReports"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"
            android:cacheColorHint="#00000000"
            android:divider="#F0DF8B"
            android:dividerHeight="1dp"
            android:padding="4dp" />
    </LinearLayout>
</LinearLayout>
