<?xml version="1.0" encoding="utf-8"?>

<!--
    Màn hình hồ sơ cá nhân của ứng dụng MomentShare.
    File này thuộc phần Người 1 - Tài khoản, hồ sơ cá nhân.

    Chức năng:
    - Hiển thị avatar người dùng.
    - Hiển thị họ tên, username, email và bio.
    - Hiển thị thống kê cơ bản: số bạn bè, ảnh đã gửi, ảnh đã nhận.
    - Cho phép chuyển sang màn hình chỉnh sửa hồ sơ.
    - Cho phép đăng xuất khỏi tài khoản hiện tại.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tiêu đề màn hình -->
        <TextView
            android:id="@+id/txtProfileTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hồ sơ cá nhân"
            android:textAlignment="center"
            android:textColor="#222222"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Avatar tạm thời của người dùng -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:contentDescription="Ảnh đại diện"
            android:src="@mipmap/ic_launcher_round" />

        <!-- Họ tên người dùng -->
        <TextView
            android:id="@+id/txtFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Họ tên người dùng"
            android:textAlignment="center"
            android:textColor="#222222"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Username người dùng -->
        <TextView
            android:id="@+id/txtUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@username"
            android:textAlignment="center"
            android:textColor="#777777"
            android:textSize="15sp" />

        <!-- Email người dùng -->
        <TextView
            android:id="@+id/txtEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="email@example.com"
            android:textAlignment="center"
            android:textColor="#777777"
            android:textSize="15sp" />

        <!-- Bio / mô tả cá nhân -->
        <TextView
            android:id="@+id/txtBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#F5F5F5"
            android:padding="14dp"
            android:text="Chưa có mô tả cá nhân"
            android:textAlignment="center"
            android:textColor="#444444"
            android:textSize="14sp" />

        <!-- Khu vực thống kê cơ bản.
             Các số liệu này có thể nối dữ liệu thật sau khi module Friends và Moment hoàn thành.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Số bạn bè -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtFriendCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn bè"
                    android:textColor="#777777"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Số ảnh đã gửi -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtSentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã gửi"
                    android:textColor="#777777"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Số ảnh đã nhận -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtReceivedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã nhận"
                    android:textColor="#777777"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <!--
            Nút chuyển sang màn hình chỉnh sửa hồ sơ.
            ID này phải trùng với ProfileActivity.java:
            findViewById(R.id.btnEditProfile)
        -->
        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:minHeight="50dp"
            android:text="Chỉnh sửa hồ sơ"
            android:textAllCaps="false" />

        <!-- Nút đăng xuất khỏi tài khoản hiện tại -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="50dp"
            android:text="Đăng xuất"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>
