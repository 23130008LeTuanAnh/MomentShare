<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Theme gốc của ứng dụng MomentShare -->
    <style name="Base.Theme.MomentShare" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Màu chính -->
        <item name="colorPrimary">@color/ms_primary</item>
        <item name="colorPrimaryDark">@color/ms_primary_dark</item>
        <item name="colorSecondary">@color/ms_primary_light</item>
        <item name="colorAccent">@color/ms_primary</item>

        <!-- Nền app -->
        <item name="android:windowBackground">@color/ms_screen</item>

        <!-- Thanh trạng thái và thanh điều hướng -->
        <item name="android:statusBarColor">@color/ms_screen</item>
        <item name="android:navigationBarColor">@color/ms_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Không cho Android tự ép giao diện tối gây đen màn hình -->
        <item name="android:forceDarkAllowed">false</item>

        <!-- Font mặc định -->
        <item name="android:fontFamily">sans</item>

        <!-- Style mặc định cho các component Material -->
        <item name="materialButtonStyle">@style/Widget.MomentShare.Button</item>
        <item name="textInputStyle">@style/Widget.MomentShare.TextInputLayout</item>
        <item name="materialCardViewStyle">@style/Widget.MomentShare.Card</item>

    </style>

    <!-- Theme chính được gọi trong AndroidManifest.xml -->
    <style name="Theme.MomentShare" parent="Base.Theme.MomentShare" />


    <!-- ========================= -->
    <!-- BUTTON STYLE -->
    <!-- ========================= -->

    <!-- Nút chính mặc định của app -->
    <style name="Widget.MomentShare.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/ms_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Nút viền phụ nếu cần dùng trong XML -->
    <style name="Widget.MomentShare.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/ms_primary</item>
        <item name="android:textColor">@color/ms_primary</item>
        <item name="android:minHeight">48dp</item>
    </style>


    <!-- ========================= -->
    <!-- TEXT INPUT STYLE -->
    <!-- ========================= -->

    <!-- Ô nhập mặc định dùng cho Login/Register/Edit Profile -->
    <style name="Widget.MomentShare.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/ms_primary</item>
        <item name="hintTextColor">@color/ms_primary</item>
        <item name="boxBackgroundColor">@color/ms_surface</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>


    <!-- ========================= -->
    <!-- CARD STYLE -->
    <!-- ========================= -->

    <!-- Card mặc định: nền trắng, bo góc mềm -->
    <style name="Widget.MomentShare.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/ms_surface</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/ms_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>


    <!-- ========================= -->
    <!-- SHAPE APPEARANCE STYLE -->
    <!-- ========================= -->

    <!-- 
        Style này sửa lỗi:
        resource style/ShapeAppearance.MomentShare not found
    -->
    <style name="ShapeAppearance.MomentShare">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Bo góc nhỏ -->
    <style name="ShapeAppearance.MomentShare.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Bo góc vừa -->
    <style name="ShapeAppearance.MomentShare.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Bo góc lớn -->
    <style name="ShapeAppearance.MomentShare.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Avatar / ảnh tròn -->
    <style name="ShapeAppearance.MomentShare.CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Tên rút gọn nếu layout cũ gọi @style/CircleImage -->
    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>


    <!-- ========================= -->
    <!-- TEXT STYLE -->
    <!-- ========================= -->

    <!-- Tiêu đề lớn -->
    <style name="TextAppearance.MomentShare.Title">
        <item name="android:textColor">@color/ms_text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tiêu đề vừa -->
    <style name="TextAppearance.MomentShare.Subtitle">
        <item name="android:textColor">@color/ms_text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Text nội dung -->
    <style name="TextAppearance.MomentShare.Body">
        <item name="android:textColor">@color/ms_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Text phụ -->
    <style name="TextAppearance.MomentShare.Caption">
        <item name="android:textColor">@color/ms_text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>
